# Copy this file to .env and adjust values
# Example:
#   cp .env.example .env
#   chmod 600 .env

# Required
HOSTNAME_SHORT="xxx-host"
TS_AUTHKEY="tskey-auth-REDACTED"

# Optional domains
PRIMARY_DOMAIN="domain.eu"
EXTRA_DOMAINS="ts.domain.eu,alt.domain.eu"

# Optional user / SSH settings
NEW_USER="veloadmin"
SSH_PORT="10022"
KEEP_SSH_PORT_22="true"

# SSH keys (pick one):
# Option A: pull keys from a GitHub user profile
GITHUB_KEYS_USER="senecjusz"

# Option B: pull an authorized_keys file from a URL (comment out GITHUB_KEYS_USER if you use this)
# AUTHORIZED_KEYS_URL="https://raw.githubusercontent.com/<org>/<repo>/<ref>/authorized_keys"
